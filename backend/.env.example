# Local development example (do not commit real secrets)
PORT=5001
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/university_db
JWT_SECRET=dev_secret_change_me
FRONTEND_URL=http://localhost:5173
# Optional: Rate limiting (enabled by default)
# - In development, the backend defaults to a higher limit to avoid 429s while the UI loads.
# - Set RATE_LIMIT_ENABLED=false to disable completely (not recommended for production).
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=5000
#
# Optional: If you use MongoDB Atlas (mongodb+srv://...) and your network DNS blocks SRV lookups,
# set custom DNS servers for this Node process:
# DNS_SERVERS=1.1.1.1,8.8.8.8
#
# Note: If your Atlas password contains special characters (e.g. `#`, `@`, `:`),
# URL-encode it (or regenerate a password without special chars) and wrap MONGO_URI in quotes.
