{
  "name": "ace-erp",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:backend": "node scripts/dev.mjs --backend",
    "dev:frontend": "node scripts/dev.mjs --frontend",
    "dev:db": "docker compose up -d mongo",
    "build": "npm --prefix backend run build && npm --prefix frontend run build",
    "start:backend": "npm --prefix backend run start",
    "preview:frontend": "npm --prefix frontend run preview"
  }
}
